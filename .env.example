### APP
CS_NETWORK=
DEFAULT_LANGUAGE=
# Comma-separated origins for production CORS. In development (NODE_ENV != production) all origins are allowed.
ALLOWED_ORIGIN=http://localhost:5000,*.craftscript.com

# Orchestrator production secrets (Vault on host; names only in catalog)
# DATABASE_URL=
# API_SIGNING_KEY=

### DB
DB_CLIENT=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

DB_LOGGING=
SERVER_PORT=

HYPERLIQUID_API_URL=
HYPERLIQUID_WS_URL=

CS_I18N_SERVICE_URL=

ONE_CLICK_API_URL=
ONE_CLICK_API_JWT=
SOLVER_RELAY_API_URL=
SOLVER_RELAY_TIMEOUT_MS=5000
SWAP_MAX_SLIPPAGE_BPS=1000
SWAP_MIN_DEADLINE_MS=60000
ASSETS_CACHE_TTL_MS=300000

### Privy end-user onboarding
PRIVY_APP_ID=
# Public verification key from Privy dashboard. Use PEM or base64url DER SPKI.
PRIVY_VERIFICATION_KEY=
# Browser-safe comma-separated login methods exposed by /api/v1/public/auth-config.
PRIVY_LOGIN_METHODS=email,google,apple,passkey
# Browser-safe onboarding capability flags exposed by /api/v1/public/auth-config.
PRIVY_EMBEDDED_WALLET_ENABLED=true
EXTERNAL_WALLET_BINDING_ENABLED=true
# Development only: set true to allow unsigned local JWT claim validation without signature verification.
PRIVY_AUTH_DEV_ALLOW_UNSIGNED=false
